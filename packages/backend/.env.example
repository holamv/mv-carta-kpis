# Servidor
PORT=4000
NODE_ENV=development

# CORS - origen permitido del frontend
CORS_ORIGIN=http://localhost:3000

# Base de datos directa (MySQL)
DB_ACCESS_TYPE=mysql        # mysql | postgres
DB_ACCESS_HOST=
DB_ACCESS_PORT=3306         # 3306 MySQL, 5432 PostgreSQL
DB_ACCESS_USER=
DB_ACCESS_PASSWORD=
DB_ACCESS_NAME=
